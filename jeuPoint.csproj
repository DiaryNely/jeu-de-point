<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="9.0.203" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="9.0.203" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="9.0.203" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.0.203" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="9.0.203" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="9.0.203" />
    <PackageReference Include="Microsoft.Extensions.Logging.Debug" Version="9.0.203" />
    <PackageReference Include="Npgsql" Version="9.0.3" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>